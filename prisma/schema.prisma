// Prisma schema for Person App
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  age       Int?
  city      String?
  country   String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
