// Prisma schema for Person App
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  role      String?
  age       Int?
  city      String?
  country   String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Append-only audit log of MCP tool invocations. Powers the /mcp-demo page.
model McpEvent {
  id        String   @id @default(cuid())
  tool      String
  payload   Json?
  result    String
  createdAt DateTime @default(now())

  @@index([createdAt])
}
